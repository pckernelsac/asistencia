# Variables de entorno para producción
# Copia este archivo a .env y configura tus valores

# Flask Secret Key (IMPORTANTE: Genera uno único y seguro)
# Puedes generar uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-secura-generada-aleatoriamente

# Modo de ambiente
FLASK_ENV=production

# Base de datos (SQLite por defecto, path absoluto en producción)
# DB_PATH=/home/usuario/festihack/instance/asistencia.db

# Upload folder (path absoluto en producción)
# UPLOAD_FOLDER=/home/usuario/festihack/static/uploads

# Configuración de sesión
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Timezone
TZ=America/Lima

# --- Supabase (tu proyecto) ---
# Dashboard: https://supabase.com/dashboard/project/wsmpqibskajjxcpvuleq
SUPABASE_URL=https://wsmpqibskajjxcpvuleq.supabase.co

# Settings → API → anon public (frontend o pruebas con RLS)
SUPABASE_ANON_KEY=

# Settings → API → service_role (SOLO servidor Flask; nunca en el navegador ni en repos)
SUPABASE_SERVICE_ROLE_KEY=

# Settings → Database → copia la contraseña del usuario `postgres` y sustituye [YOUR-PASSWORD]
# Añade sslmode=require si tu cliente lo exige (psycopg suele necesitarlo en producción).

# Pooler (puerto 6543): uso habitual desde Flask / app en producción
# Codifica la contraseña en la URL (urllib.parse.quote(password, safe='')) si tiene ! # , etc.
# psycopg no acepta el parámetro pgbouncer en la URI: usa ?sslmode=require (sin pgbouncer=true).
DATABASE_URL=postgresql://postgres.wsmpqibskajjxcpvuleq:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require

# Conexión directa (puerto 5432): migraciones, DDL, herramientas que no van bien con PgBouncer
DIRECT_URL=postgresql://postgres.wsmpqibskajjxcpvuleq:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# SaaS (Postgres): tras ejecutar sql/supabase_schema.sql en Supabase, crear admin e institución:
#   flask --app app bootstrap-admin
# Opcional: BOOTSTRAP_ADMIN_USER, BOOTSTRAP_ADMIN_PASSWORD, BOOTSTRAP_INSTITUTION_NAME
#
# Si la base ya existía antes, ejecute UNA VEZ sql/migration_002_institution_approval.sql (SQL Editor / DIRECT_URL).
#
# Super administrador (aprueba instituciones nuevas):
# - En SQLite: el usuario "admin" creado por defecto es super master; otros usuarios vía columna is_super_master en BD.
# - En Postgres: bootstrap-admin marca al usuario bootstrap como super master.
# - Opcional: lista de usuarios adicionales (coma-separados), sin tocar la BD:
# SUPER_MASTER_USERNAMES=admin,otro_super
